PORT=8088
DATA_SOURCE=auto
REFRESH_SECONDS=30

# cscli source: run cscli inside an existing CrowdSec container.
CROWDSEC_CONTAINER=crowdsec
CSCLI_COMMAND=cscli alerts list -o json --limit 250

# LAPI alerts source: watcher login.
LAPI_URL=http://127.0.0.1:8080
LAPI_LOGIN=
LAPI_PASSWORD=

# LAPI decisions source: bouncer key.
LAPI_API_KEY=

# Optional public IP shown next to the Live attacks title.
PUBLIC_TARGET_IP=
PUBLIC_TARGET_IP_AUTO=true
PUBLIC_TARGET_IP_REFRESH_MINUTES=60

# Optional CrowdSec CTI reputation enrichment.
CTI_API_KEY=
CTI_CACHE_FILE=data/cti-cache.json
CTI_CACHE_HOURS=72

# Optional demo visit logging. Logs only HTML page visits, not API calls or assets.
TRUST_PROXY=true
ACCESS_LOG_ENABLED=false
ACCESS_LOG_FILE=data/access-log.jsonl
ACCESS_LOG_RETENTION_DAYS=30
